## Secrets — resolved by `op run` at startup
KOMODO_DB_USERNAME=komodo
KOMODO_DB_PASSWORD=op://Homelab/Komodo DB Password/password
KOMODO_PASSKEY=op://Homelab/Komodo Passkey/password
KOMODO_JWT_SECRET=op://Homelab/Komodo JWT Secret/password
KOMODO_WEBHOOK_SECRET=op://Homelab/Komodo Webhook Secret/password
KOMODO_INIT_ADMIN_USERNAME=nathan
KOMODO_INIT_ADMIN_PASSWORD=op://Homelab/Komodo Admin Password/password

## Core config
KOMODO_HOST=https://komodo.pod.haus
KOMODO_TITLE=PodHaus
KOMODO_FIRST_SERVER=https://periphery:8120
KOMODO_FIRST_SERVER_NAME=podhaus
KOMODO_LOCAL_AUTH=true
KOMODO_DISABLE_USER_REGISTRATION=true
TZ=Australia/Perth

## Backups
COMPOSE_KOMODO_BACKUPS_PATH=/opt/komodo/backups

## Repo root (mounted into Core for ResourceSync, and Periphery for compose files).
## NOT set here — komodo-start exports COMPOSE_KOMODO_REPO_PATH=$(pwd) so the
## value tracks wherever the repo is checked out, keeping podhaus portable
## across hosts and clones.
