#!/bin/bash
set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")"
export OP_SERVICE_ACCOUNT_TOKEN="$(cat OP_SERVICE_ACCOUNT_TOKEN)"

# Repo root is auto-discovered from the script's working directory. Keeps
# podhaus portable: clone anywhere, run ./komodo-start, and Komodo + every
# stack that interpolates [[PODHAUS_REPO]] points at this checkout.
export COMPOSE_KOMODO_REPO_PATH="$PWD"

# Pre-create /etc/komodo/ssl so komodo-periphery can write its self-signed
# certs there (the image doesn't mkdir -p the ssl subdir on its own).
sudo mkdir -p /etc/komodo/ssl

op run --env-file komodo/compose.env -- \
  docker compose -p komodo -f komodo/ferretdb.compose.yaml --env-file komodo/compose.env up -d

echo "Waiting for Komodo Core..."
until curl -sf -o /dev/null http://localhost:9120/; do
  sleep 2
done
echo "Komodo Core is ready"

api_key=$(op read "op://Homelab/Komodo API OnePassword Sync/username")
api_secret=$(op read "op://Homelab/Komodo API OnePassword Sync/credential")

komodo_api() {
  local endpoint="$1" payload="$2"
  curl -sf -X POST "http://localhost:9120/${endpoint}" \
    -H "Content-Type: application/json" \
    -H "X-Api-Key: ${api_key}" \
    -H "X-Api-Secret: ${api_secret}" \
    -d "$payload"
}

seed_variable() {
  local name="$1" value="$2" is_secret="${3:-true}"
  local create_payload update_payload
  create_payload=$(jq -n --arg n "$name" --arg v "$value" --argjson s "$is_secret" \
    '{type: "CreateVariable", params: {name: $n, value: $v, is_secret: $s}}')
  update_payload=$(jq -n --arg n "$name" --arg v "$value" \
    '{type: "UpdateVariableValue", params: {name: $n, value: $v}}')
  komodo_api write "$create_payload" > /dev/null 2>&1 || \
    komodo_api write "$update_payload" > /dev/null
  echo "  ${name}"
}

echo "Seeding 1Password variables into Komodo..."
seed_variable "ONEPASSWORD_CREDENTIALS" \
  "$(op document get "Homelab Credentials File" --vault Homelab)"
seed_variable "ONEPASSWORD_CONNECT_TOKEN" \
  "$(op read "op://Homelab/Homelab Access Token Komodo/credential")"
seed_variable "ONEPASSWORD_API_KEY" "$api_key"
seed_variable "ONEPASSWORD_API_SECRET" "$api_secret"

# Non-secret variables from komodo/sync/variables.toml. Komodo ResourceSync
# reads that file as remote content but does not apply [[variable]] entries,
# so declarations there never become live variables — which silently breaks
# [[TZ]] / [[MEDIA_DIR]] interpolation in stack.toml environment blocks on
# the next redeploy. Seed them here so they're always present post-bootstrap.
echo "Seeding non-secret variables into Komodo..."
seed_variable "TZ"            "Australia/Perth" false
seed_variable "MEDIA_DIR"     "/mnt/pouch"      false
# Host path to this repo checkout. Stacks that bind-mount files out of
# the repo (logging configs, cloudflare-tunnel ingress rules, etc.)
# interpolate [[PODHAUS_REPO]] in their stack.toml environment block so
# the rendered compose file uses ${PODHAUS_REPO}/<stack>/<file>. This is
# what keeps the repo portable — bilby has it at /home/nathan/repos/podhaus,
# the next host could clone it anywhere and the same compose files work.
seed_variable "PODHAUS_REPO"  "$PWD"            false

echo "Rendering host-side secret files..."
# Secrets (or large multi-line blobs) don't round-trip through Komodo's
# env-file pipeline, so we render them to files under /etc/komodo/ on
# the host and bind-mount them into the containers that need them.
#
# rclone.conf: structural config (remote name, drive_id, drive_type,
# region) is in backup/rclone.conf.tmpl in the repo so it's git-tracked
# and reviewable. Only the OAuth token JSON blob lives in 1P as a
# Secure Note. envsubst assembles them at render time.
#
# IMPORTANT: the rendered file on disk is not the long-term source of
# truth for the token — rclone rewrites the token field in place every
# time it refreshes OAuth. The 1P copy is used only on bootstrap; after
# first rclone use the disk is authoritative. The 1P token is valid for
# roughly 1-2 days of fresh use before OneDrive invalidates the last
# stored refresh_token; re-OAuth on a laptop and update 1P if the token
# has gone stale (the recipe is in backup/rclone.conf.tmpl's comment).
sudo mkdir -p /etc/komodo/rclone
RCLONE_ONEDRIVE_TOKEN="$(op read 'op://Homelab/rclone-onedrive-token/notesPlain')" \
  envsubst '${RCLONE_ONEDRIVE_TOKEN}' < backup/rclone.conf.tmpl | \
  sudo tee /etc/komodo/rclone/rclone.conf > /dev/null
sudo chmod 600 /etc/komodo/rclone/rclone.conf
echo "  /etc/komodo/rclone/rclone.conf"

# Backrest config: repo + plans + retention + rclone-sync hook declared in
# backup/config.json.tmpl. Only secret is RESTIC_REPO_PASSWORD from 1P. We
# render to /etc/komodo/backup/config.json and bind-mount read-only into
# the backrest container so the repo is the authoritative source for
# plans — UI edits to the config can't persist by design.
sudo mkdir -p /etc/komodo/backup
RESTIC_REPO_PASSWORD="$(op read 'op://Homelab/restic-repo-password/credential')" \
  envsubst '${RESTIC_REPO_PASSWORD}' < backup/config.json.tmpl | \
  sudo tee /etc/komodo/backup/config.json > /dev/null
sudo chmod 600 /etc/komodo/backup/config.json
echo "  /etc/komodo/backup/config.json"

# Plex Preferences.xml: identity + config attrs enforced from the
# template, PlexOnlineToken from 1P. The merge script overlays
# enforced attrs onto the existing Preferences.xml (preserving all
# runtime state Plex has written), or seeds a fresh file on first boot.
PLEX_PREFS="/var/lib/plex-local/Library/Application Support/Plex Media Server/Preferences.xml"
PLEX_ONLINE_TOKEN="$(op read 'op://Homelab/Plex Online Token/credential')" \
  envsubst '${PLEX_ONLINE_TOKEN}' < plex/Preferences.xml.tmpl > /tmp/plex-prefs-rendered.xml
python3 plex/plex-preferences.py /tmp/plex-prefs-rendered.xml "$PLEX_PREFS"
rm -f /tmp/plex-prefs-rendered.xml

./komodo-sync
