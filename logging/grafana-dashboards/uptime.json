{
  "uid": "uptime",
  "title": "Uptime Status",
  "tags": ["podhaus", "uptime"],
  "timezone": "browser",
  "refresh": "2m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Endpoint Status",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://gatus:8080/api/v1/endpoints/statuses",
          "parser": "backend",
          "root_selector": "",
          "columns": [
            { "selector": "name", "text": "Endpoint", "type": "string" },
            { "selector": "group", "text": "Group", "type": "string" },
            { "selector": "key", "text": "Key", "type": "string" },
            { "selector": "results.0.success", "text": "Current", "type": "boolean" },
            { "selector": "results.0.duration", "text": "Latency (ms)", "type": "number" },
            { "selector": "results.0.hostname", "text": "Hostname", "type": "string" },
            { "selector": "results.0.conditionResults.0.success", "text": "Status Check", "type": "boolean" }
          ],
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Current" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "true": { "text": "UP", "color": "green" }, "false": { "text": "DOWN", "color": "red" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Key" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          { "displayName": "Current", "desc": false }
        ]
      }
    }
  ],
  "schemaVersion": 39
}
