{
  "uid": "uptime",
  "title": "Uptime Status",
  "tags": ["podhaus", "uptime"],
  "timezone": "browser",
  "refresh": "2m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Endpoint Status",
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://gatus:8080/api/v1/endpoints/statuses",
          "url_options": { "method": "GET" },
          "parser": "backend",
          "root_selector": "",
          "columns": [
            { "selector": "name", "text": "Endpoint", "type": "string" },
            { "selector": "group", "text": "Group", "type": "string" },
            { "selector": "results.0.success", "text": "Status", "type": "boolean" },
            { "selector": "results.0.duration", "text": "Latency", "type": "number" }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": { "text": "UP", "color": "green" },
                      "false": { "text": "DOWN", "color": "red" }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Latency" },
            "properties": [
              { "id": "unit", "value": "ns" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Status", "desc": false }]
      }
    }
  ],
  "schemaVersion": 39
}
