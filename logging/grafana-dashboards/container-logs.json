{
  "uid": "container-logs",
  "title": "Container Logs",
  "tags": ["podhaus", "logs"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "All Container Logs",
      "gridPos": { "h": 24, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "victoriametrics-logs-datasource" },
      "targets": [
        {
          "refId": "A",
          "expr": "*",
          "maxLines": 1000
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39
}
