#!/bin/bash
set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")"
export OP_SERVICE_ACCOUNT_TOKEN="$(cat OP_SERVICE_ACCOUNT_TOKEN)"

api_key=$(op read "op://Homelab/Komodo API OnePassword Sync/username")
api_secret=$(op read "op://Homelab/Komodo API OnePassword Sync/credential")

komodo_api() {
  local endpoint="$1" payload="$2"
  curl -sf -X POST "http://localhost:9120/${endpoint}" \
    -H "Content-Type: application/json" \
    -H "X-Api-Key: ${api_key}" \
    -H "X-Api-Secret: ${api_secret}" \
    -d "$payload"
}

echo "Creating Resource Sync..."
komodo_api write '{
  "type": "CreateResourceSync",
  "params": {
    "name": "podhaus",
    "config": {
      "files_on_host": true,
      "resource_path": ["."]
    }
  }
}' > /dev/null 2>&1 || true

echo "Running initial sync..."
komodo_api execute '{
  "type": "RunSync",
  "params": { "sync": "podhaus" }
}' > /dev/null

echo "Waiting for komodo-op to sync secrets..."
while true; do
  count=$(komodo_api read '{"type": "ListVariables", "params": {}}' | jq 'length')
  if [ "$count" -gt 4 ]; then
    echo "  ${count} variables found (komodo-op has synced)"
    break
  fi
  sleep 5
done

echo "Running second sync..."
komodo_api execute '{
  "type": "RunSync",
  "params": { "sync": "podhaus" }
}' > /dev/null

echo "Done"
